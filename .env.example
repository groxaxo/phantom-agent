# ── LLM Configuration ──────────────────────────────────────────
# OpenAI-compatible endpoint (vLLM, llama.cpp, Ollama, OpenAI, etc.)
LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
LLM_MODEL=glm-5-turbo
LLM_API_KEY=
LLM_TEMPERATURE=0.1

# ── Browser Configuration ─────────────────────────────────────
# Path to Chromium executable (auto-detected if empty)
CHROME_PATH=
# Connect to existing browser via WebSocket
CHROME_WS_ENDPOINT=
# Launch headless (true/false). Default is headed unless overridden.
HEADLESS=false
# Custom user-data-dir (empty = auto-detect your local Chrome/Chromium profile)
USER_DATA_DIR=
# Specific profile inside the user-data-dir (e.g. Default, Profile 1)
PROFILE_DIRECTORY=
# Viewport dimensions
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# ── Agent Configuration ───────────────────────────────────────
MAX_STEPS=40
STEP_DELAY_MS=400
# Enable screenshot-based vision (requires multimodal LLM)
ENABLE_VISION=false

# ── Stealth Configuration ─────────────────────────────────────
# Override user agent string (empty = realistic default)
USER_AGENT=
# Spoof WebGL vendor/renderer
WEBGL_VENDOR=Intel Inc.
WEBGL_RENDERER=Intel Iris OpenGL Engine
# Timezone override
TIMEZONE=America/New_York
# Locale override
LOCALE=en-US
